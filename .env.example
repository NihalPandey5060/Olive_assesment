# Copy this file to .env and fill values

# Local Ollama runtime
OLLAMA_BASE_URL=http://localhost:11434

# Local models
OSS_MODEL=gemma3:1b
FRONTIER_MODEL=llama3.2:1b

# Evaluator model for hallucination judging
# Supported: ollama | openai | gemini
JUDGE_PROVIDER=gemini
JUDGE_MODEL=gemini-2.5-flash
JUDGE_API_KEY=
JUDGE_BASE_URL=http://localhost:11434
JUDGE_TEMPERATURE=0
JUDGE_TIMEOUT=120
JUDGE_MAX_RETRIES=3
EVALUATOR_MODEL=llama3.2:1b
EVALUATOR_BASE_URL=http://localhost:11434
EVALUATOR_TEMPERATURE=0
EVALUATOR_TIMEOUT_SECONDS=120
EVALUATOR_MAX_RETRIES=3

MAX_HISTORY=12